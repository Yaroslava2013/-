    # Запуск бота
@bot.message_handler(commands=['f'])
def send_welcome(message):
        bot.reply_to(message, f'с командой  random ты можешь задавать вопросы (мысленно или в слух) и бот ответит да или нет') 
@bot.message_handler(commands=['random'])
def facts(message):
     facts_me = ['да', 'нет', 'да', 'нет']
     bot.reply_to(message, random.choice(facts_me))       
bot.polling()

